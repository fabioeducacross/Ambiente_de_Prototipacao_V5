{
  "name": "ambiente-prototipacao-v5",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run start --prefix documentation",
    "dev": "vite",
    "dev:fo": "npm run dev --prefix FrontOffice",
    "dev:docs": "npm start --prefix documentation",
    "docs:index": "npm run build --prefix documentation && npm run serve --prefix documentation -- --port 3000 --host localhost",
    "plan:ascii": "node scripts/plan-progress-ascii.mjs",
    "plan:ds:context": "node scripts/show-ds-plan-context.mjs",
    "plan:ds:phase": "node scripts/update-ds-phase-status.mjs",
    "figma:capture:localhost": "node scripts/figma_capture_localhost.cjs",
    "figma:capture:guarded": "node scripts/figma_capture_guarded.cjs",
    "tokens:extract": "node scripts/tokens/run-token-pipeline.mjs",
    "predev:all": "powershell -Command \"Get-NetTCPConnection -LocalPort 5173,5174,3000 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }\"",
    "setup:ds": "npm ci --prefix design-system",
    "dev:ds": "npm run storybook --prefix design-system",
    "build:ds": "npm run build-storybook --prefix design-system",
    "dev:all": "concurrently --kill-others-on-fail -n ROOT,FO,DOCS -c blue,green,cyan \"vite --port 5173\" \"npm run dev --prefix FrontOffice\" \"npm start --prefix documentation\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "concurrently": "^9.2.1",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.3.0",
    "vite": "^7.2.4",
    "yaml": "^2.8.2"
  }
}