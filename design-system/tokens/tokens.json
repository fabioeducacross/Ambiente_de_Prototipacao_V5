{
  "meta": {
    "source": "FrontOffice/src/style.css",
    "version": "1.3.0",
    "description": "Tokens canônicos do Design System Educacross"
  },
  "color": {
    "primary": "#7367F0",
    "primary-light": "#9E95F5",
    "primary-dark": "#5E50EE",
    "ec-primary": "#6E63E8",
    "ec-primary-soft": "#EEEDFD",
    "secondary": "#82868B",
    "secondary-light": "#A8AAAE",
    "secondary-dark": "#6E7175",
    "success": "#28C76F",
    "success-light": "#55D68D",
    "success-dark": "#1FAE5F",
    "info": "#00CFE8",
    "info-light": "#33DAED",
    "info-dark": "#00B8D4",
    "warning": "#FF9F43",
    "warning-light": "#FFB569",
    "warning-dark": "#FF8C1A",
    "danger": "#EA5455",
    "danger-light": "#EE7677",
    "danger-dark": "#E73C3D",
    "white": "#FFFFFF",
    "black": "#000000",
    "gray-50": "#FAFAFA",
    "gray-100": "#F5F5F5",
    "gray-200": "#EEEEEE",
    "gray-300": "#E0E0E0",
    "gray-400": "#BDBDBD",
    "gray-500": "#9E9E9E",
    "gray-600": "#757575",
    "gray-700": "#616161",
    "gray-800": "#424242",
    "gray-900": "#212121",
    "category-missao": "#7F6CC3",
    "category-olimpiada": "#8BC728",
    "category-avaliacao": "#FE5153",
    "category-trilha": "#00A5A0",
    "category-expedicao": "#FFB443",
    "category-lembrete": "#7CD7D3"
  },
  "typography": {
    "font-family-base": "'Montserrat', Helvetica, Arial, sans-serif",
    "font-family-mono": "'Courier New', monospace",
    "font-size-xs": "0.75rem",
    "font-size-sm": "0.875rem",
    "font-size-base": "1rem",
    "font-size-lg": "1.125rem",
    "font-size-xl": "1.25rem",
    "font-size-2xl": "1.5rem",
    "font-size-3xl": "1.875rem",
    "font-size-4xl": "2.25rem"
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem",
    "3xl": "4rem"
  },
  "radius": {
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "full": "9999px"
  },
  "shadow": {
    "sm": "0 1px 3px 0 rgba(34, 41, 47, 0.08)",
    "md": "0 5px 20px 0 rgba(34, 41, 47, 0.1)",
    "lg": "0 8px 24px 0 rgba(34, 41, 47, 0.15)",
    "xl": "0 14px 40px 0 rgba(34, 41, 47, 0.18)"
  },
  "transition": {
    "fast": "150ms ease-in-out",
    "base": "250ms ease-in-out",
    "slow": "350ms ease-in-out"
  }
}
